<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Sorry My GF</title>
  <style>
    body {
      margin: 0;
      padding: 0;
      background: pink;
      font-family: Arial, sans-serif;
      overflow: hidden;
    }

    .container {
      display: flex;
      flex-direction: column;
      align-items: center;
      justify-content: center;
      height: 100vh;
      text-align: center;
      position: relative;
    }

    .cat-img {
      width: 220px;
      border-radius: 20px;
      box-shadow: 0 10px 20px rgba(0,0,0,0.2);
      margin-bottom: 20px;
    }

    .text {
      font-size: 32px;
      font-weight: bold;
      color: white;
      text-shadow: 2px 2px 4px rgba(0,0,0,0.3);
    }

    .decor {
      position: absolute;
      font-size: 30px;
      opacity: 0.8;
    }

    .top-left { top: 10px; left: 10px; }
    .top-right { top: 10px; right: 10px; }
    .bottom-left { bottom: 10px; left: 10px; }
    .bottom-right { bottom: 10px; right: 10px; }
  </style>
</head>
<body>

  <div class="decor top-left">🌸💖</div>
  <div class="decor top-right">💐🌷</div>
  <div class="decor bottom-left">🌹✨</div>
  <div class="decor bottom-right">💝🌸</div>

  <div class="container">
    <!-- Replace cat.jpg with your image filename -->
    <img class="cat-img" src="cat.jpg" alt="cat holding flower" />

    <div class="text">sorry my gf 🌹</div>
  </div>

</body>
</html>
